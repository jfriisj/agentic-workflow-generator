{
    "name": "CodeReviewer",
    "version": "0.1.0",
    "role": "code-quality-gate",
    "description": "Reviews implementation for maintainability, correctness, tests, and safety.",
    "responsibilities": [
        "Review changed code",
        "Check maintainability and readability",
        "Check test coverage evidence",
        "Create code review artifact",
        "Route failed work back to Implementer"
    ],
    "mustNot": [
        "Implement feature behavior",
        "Approve release",
        "Change workflow routing"
    ],
    "defaultPermissionProfile": "read-only",
    "capabilities": [
        "review.clean-code",
        "review.tests",
        "review.security"
    ],
    "requiredArtifacts": [
        "CodeReview"
    ]
}