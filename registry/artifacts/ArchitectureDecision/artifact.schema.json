{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agentic/artifacts/architecture-decision.schema.json",
  "title": "ArchitectureDecision Artifact Contract",
  "type": "object",
  "required": [
    "type",
    "description",
    "pathPattern",
    "status",
    "allowedStatuses",
    "requiredHeadings"
  ],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "const": "ArchitectureDecision"
    },
    "description": {
      "type": "string",
      "const": "Artifact contract for architecture decision output produced by Architect agents."
    },
    "pathPattern": {
      "type": "string",
      "const": "agent-output/architecture-decision/*.md"
    },
    "status": {
      "type": "object",
      "required": [
        "heading",
        "pattern"
      ],
      "additionalProperties": false,
      "properties": {
        "heading": {
          "type": "string",
          "const": "## Status"
        },
        "pattern": {
          "type": "string",
          "const": "PASS|FAIL|BLOCKED"
        }
      }
    },
    "allowedStatuses": {
      "type": "array",
      "prefixItems": [
        {
          "type": "string",
          "const": "PASS"
        },
        {
          "type": "string",
          "const": "FAIL"
        },
        {
          "type": "string",
          "const": "BLOCKED"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true
    },
    "requiredHeadings": {
      "type": "array",
      "prefixItems": [
        {
          "type": "string",
          "const": "# Architecture Decision"
        },
        {
          "type": "string",
          "const": "## Status"
        },
        {
          "type": "string",
          "const": "## Summary"
        },
        {
          "type": "string",
          "const": "## Context"
        },
        {
          "type": "string",
          "const": "## Decision"
        },
        {
          "type": "string",
          "const": "## Alternatives Considered"
        },
        {
          "type": "string",
          "const": "## Consequences"
        },
        {
          "type": "string",
          "const": "## Handoff Target"
        }
      ],
      "items": false,
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true
    }
  }
}
