{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agentic/artifacts/code-review.schema.json",
  "title": "CodeReview Artifact Contract",
  "type": "object",
  "required": [
    "type",
    "description",
    "pathPattern",
    "status",
    "allowedStatuses",
    "requiredHeadings"
  ],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "const": "CodeReview"
    },
    "description": {
      "type": "string",
      "const": "Artifact contract for code review gate output."
    },
    "pathPattern": {
      "type": "string",
      "const": "agent-output/code-review/*.md"
    },
    "status": {
      "type": "object",
      "required": [
        "heading",
        "pattern"
      ],
      "additionalProperties": false,
      "properties": {
        "heading": {
          "type": "string",
          "const": "## Status"
        },
        "pattern": {
          "type": "string",
          "const": "PASS|FAIL|BLOCKED"
        }
      }
    },
    "allowedStatuses": {
      "type": "array",
      "prefixItems": [
        {
          "type": "string",
          "const": "PASS"
        },
        {
          "type": "string",
          "const": "FAIL"
        },
        {
          "type": "string",
          "const": "BLOCKED"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true
    },
    "requiredHeadings": {
      "type": "array",
      "prefixItems": [
        {
          "type": "string",
          "const": "# Code Review"
        },
        {
          "type": "string",
          "const": "## Status"
        },
        {
          "type": "string",
          "const": "## Summary"
        },
        {
          "type": "string",
          "const": "## Evidence Reviewed"
        },
        {
          "type": "string",
          "const": "## Findings"
        },
        {
          "type": "string",
          "const": "## Required Fixes"
        },
        {
          "type": "string",
          "const": "## Handoff Target"
        }
      ],
      "items": false,
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true
    }
  }
}
