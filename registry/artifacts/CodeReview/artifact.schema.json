{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agentic/artifacts/code-review.schema.json",
  "title": "CodeReview Artifact Contract",
  "type": "object",
  "required": [
    "type",
    "status",
    "requiredHeadings",
    "allowedStatuses"
  ],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "const": "CodeReview"
    },
    "status": {
      "type": "object",
      "required": ["heading", "pattern"],
      "additionalProperties": false,
      "properties": {
        "heading": {
          "type": "string",
          "const": "## Status"
        },
        "pattern": {
          "type": "string",
          "const": "PASS|FAIL|BLOCKED"
        }
      }
    },
    "allowedStatuses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["PASS", "FAIL", "BLOCKED"]
      },
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true
    },
    "requiredHeadings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 6,
      "uniqueItems": true
    },
    "pathPattern": {
      "type": "string"
    },
    "description": {
      "type": "string"
    }
  }
}
