{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agentic/artifacts/implementation-report.schema.json",
  "title": "ImplementationReport Artifact Contract",
  "type": "object",
  "required": [
    "type",
    "description",
    "pathPattern",
    "status",
    "allowedStatuses",
    "requiredHeadings"
  ],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "const": "ImplementationReport"
    },
    "description": {
      "type": "string",
      "const": "Artifact contract for implementation output produced by Implementer agents."
    },
    "pathPattern": {
      "type": "string",
      "const": "agent-output/implementation/*.md"
    },
    "status": {
      "type": "object",
      "required": [
        "heading",
        "pattern"
      ],
      "additionalProperties": false,
      "properties": {
        "heading": {
          "type": "string",
          "const": "## Status"
        },
        "pattern": {
          "type": "string",
          "const": "PASS|FAIL|BLOCKED"
        }
      }
    },
    "allowedStatuses": {
      "type": "array",
      "prefixItems": [
        {
          "type": "string",
          "const": "PASS"
        },
        {
          "type": "string",
          "const": "FAIL"
        },
        {
          "type": "string",
          "const": "BLOCKED"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true
    },
    "requiredHeadings": {
      "type": "array",
      "prefixItems": [
        {
          "type": "string",
          "const": "# Implementation Report"
        },
        {
          "type": "string",
          "const": "## Status"
        },
        {
          "type": "string",
          "const": "## Summary"
        },
        {
          "type": "string",
          "const": "## Files Changed"
        },
        {
          "type": "string",
          "const": "## Implementation Notes"
        },
        {
          "type": "string",
          "const": "## Validation Performed"
        },
        {
          "type": "string",
          "const": "## Known Risks"
        },
        {
          "type": "string",
          "const": "## Handoff Target"
        }
      ],
      "items": false,
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true
    }
  }
}
