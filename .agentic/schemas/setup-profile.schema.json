{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/setup-profile.schema.json",
  "title": "Agentic Guided Setup Profile",
  "type": "object",
  "required": [
    "schemaVersion",
    "mode",
    "setup",
    "answers",
    "selected",
    "policy"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "enum": [
        "0.1.0"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "greenfield",
        "brownfield"
      ]
    },
    "setup": {
      "type": "string",
      "minLength": 1
    },
    "answers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "question",
          "selected"
        ],
        "additionalProperties": false,
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1
          },
          "selected": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "selected": {
      "type": "object",
      "required": [
        "bundle",
        "profile",
        "workflow",
        "agents",
        "skills",
        "artifacts",
        "targets"
      ],
      "additionalProperties": false,
      "properties": {
        "bundle": {
          "type": "string",
          "minLength": 1
        },
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "agents": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "skills": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "failFast",
        "fallbackAllowed"
      ],
      "additionalProperties": false,
      "properties": {
        "failFast": {
          "type": "boolean"
        },
        "fallbackAllowed": {
          "type": "boolean"
        }
      }
    }
  }
}
