{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "output-manifest.schema.json",
  "title": "Generated Output Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "description",
    "targets",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "registryPath",
          "ownedPaths",
          "generatedFiles",
          "generatedFileCount"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "registryPath": {
            "type": "string",
            "minLength": 1
          },
          "ownedPaths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "generatedFiles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "path",
                "sha256",
                "bytes"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                },
                "bytes": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "additionalProperties": false
            }
          },
          "generatedFileCount": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "targetCount",
        "generatedFileCount",
        "errorCount",
        "errors"
      ],
      "properties": {
        "targetCount": {
          "type": "integer",
          "minimum": 1
        },
        "generatedFileCount": {
          "type": "integer",
          "minimum": 0
        },
        "errorCount": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
