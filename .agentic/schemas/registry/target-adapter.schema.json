{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "target-adapter.schema.json",
  "title": "Target Adapter Registry Entry",
  "type": "object",
  "required": [
    "name",
    "description",
    "version",
    "outputPaths",
    "ownedPaths"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "type": "string",
      "minLength": 1
    },
    "output": {
      "type": "object"
    },
    "outputs": {
      "type": "array"
    },
    "files": {
      "type": "array"
    },
    "generatedFiles": {
      "type": "array"
    },
    "conventions": {
      "type": "object"
    },
    "capabilities": {
      "type": "array"
    },
    "supports": {
      "type": "array"
    },
    "outputPaths": {
      "type": "object"
    },
    "ownedPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
