{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "target-adapter.schema.json",
  "title": "Target Adapter Registry Entry",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "generator": {
      "type": "string"
    },
    "output": {
      "type": "object"
    },
    "outputs": {
      "type": "array"
    },
    "files": {
      "type": "array"
    }
  }
}
