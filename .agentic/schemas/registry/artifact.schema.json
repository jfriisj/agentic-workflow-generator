{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifact.schema.json",
  "title": "Artifact Contract Registry Entry",
  "type": "object",
  "required": [
    "type",
    "description",
    "pathPattern",
    "requiredHeadings",
    "allowedStatuses",
    "status"
  ],
  "properties": {
    "type": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "pathPattern": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "requiredHeadings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "allowedStatuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "status": {
      "type": "object",
      "required": [
        "heading",
        "pattern"
      ],
      "properties": {
        "heading": {
          "type": "string",
          "const": "## Status"
        },
        "pattern": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "producedBy": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "required": {
      "type": "boolean"
    }
  }
}
