{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "profile.schema.json",
  "title": "Profile Registry Entry",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "agents": {
      "type": "array"
    },
    "targets": {
      "type": "array"
    },
    "workflows": {
      "type": "array"
    },
    "skills": {
      "type": "array"
    },
    "capabilities": {
      "type": "array"
    }
  }
}
