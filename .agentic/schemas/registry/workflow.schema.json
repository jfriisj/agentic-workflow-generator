{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow.schema.json",
  "title": "Workflow Registry Entry",
  "type": "object",
  "required": ["name", "description", "states", "terminalStates"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "initialState": {
      "type": "string"
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "terminalStates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "transitions": {
      "type": "array"
    },
    "gates": {
      "type": "array"
    }
  }
}
