{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow.schema.json",
  "title": "Workflow Registry Entry",
  "type": "object",
  "required": [
    "name",
    "description",
    "version",
    "startState",
    "states",
    "terminalStates",
    "defaultFailureRoute",
    "failClosed"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "startState": {
      "type": "string",
      "minLength": 1
    },
    "defaultFailureRoute": {
      "type": "string",
      "minLength": 1
    },
    "failClosed": {
      "type": "boolean"
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "gate": {
            "type": "string",
            "minLength": 1
          },
          "terminal": {
            "type": "boolean"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "terminal": {
                  "const": true
                }
              },
              "required": [
                "terminal"
              ]
            },
            "then": {
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "agent"
                    ]
                  },
                  {
                    "required": [
                      "gate"
                    ]
                  }
                ]
              }
            },
            "else": {
              "required": [
                "agent",
                "gate"
              ]
            }
          }
        ]
      }
    },
    "terminalStates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
